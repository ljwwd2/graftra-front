                <div class="payment-methods">
                    <div class="payment-method-title">选择支付方式</div>
                    <div class="payment-method" data-method="wechat">
                        <div class="payment-method-icon">
                            <!-- 微信支付图标 -->
                            <svg viewBox="0 0 24 24" fill="none">
                                <rect width="32" height="32" rx="8" fill="#09BB07"/>
                                <path d="M8.5 8.5C8.5 7.67 9.17 7 10 7H14C14.83 7 15.5 7.67 15.5 8.5V12.5C15.5 13.33 14.83 14 14 14H10C9.17 14 8.5 13.33 8.5 12.5V8.5Z" fill="white"/>
                                <path d="M12 9C12.55 9 13 9.45 13 10C13 10.55 12.55 11 12 11C11.45 11 11 10.55 11 10C11 9.45 11.45 9 12 9Z" fill="#09BB07"/>
                            </svg>
