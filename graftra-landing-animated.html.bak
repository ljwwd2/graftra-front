                                <path d="M12 8C12.8 8 13.5 8.7 13.5 9.5C13.5 10.3 12.8 11 12 11C11.2 11 10.5 10.3 10.5 9.5C10.5 8.7 11.2 8 12 8Z" fill="white"/>
                                <path d="M8 12H16V13H8V12Z" fill="white"/>
                            </svg>
                        </div>
                        <div class="payment-method-info">
                            <div class="payment-method-name">支付宝</div>
                            <div class="payment-method-desc">支付宝快捷支付</div>
                        </div>
                        <div class="payment-method-check">
