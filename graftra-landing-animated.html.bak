    <!-- Hero 区域 -->
    <section class="hero">
        <div class="hero-bg-pattern"></div>
        <div class="hero-bg-subtle"></div>

        <div class="hero-container">
            <!-- 左侧内容 -->
            <div class="hero-left">
                <div class="hero-badge fade-in">
                    <i data-lucide="sparkles"></i>
                    AI 智能图表生成
                </div>
                <h1 class="hero-title fade-in stagger-1">
                    Graftra・文字一键变专业图表
                </h1>
                <p class="hero-slogan fade-in stagger-2">
                    不用排版、不用设计，复杂内容一眼看懂
                </p>
                <p class="hero-subtitle fade-in stagger-2">
                    Graftra 让文字自动变成清晰、高级、可直接使用的流程图与示意图。不用动手画，不用懂设计，粘贴文字就能生成专业好看的可视化图表，还能轻松编辑、修改、导出。帮你省下大量时间，让方案、汇报、文档瞬间更专业、更好懂，效率直接拉满。
                </p>
                <div class="hero-actions fade-in stagger-3">
                    <a href="app.html" class="btn btn-primary">
                        立即免费使用
                        <i data-lucide="arrow-right"></i>
                    </a>
