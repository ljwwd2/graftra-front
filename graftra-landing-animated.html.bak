    <!-- 功能展示区 -->
    <section class="features" id="features">
        <div class="section-header">
            <div class="section-label fade-in">Core Features</div>
            <h2 class="section-title fade-in stagger-1">强大的 AI 功能</h2>
            <p class="section-desc fade-in stagger-2">智能解析、自动生成、一键导出，让流程图制作效率提升 10 倍</p>
        </div>

        <div class="features-grid">
            <div class="feature-card scale-in stagger-1">
                <div class="feature-icon">
                    <i data-lucide="file-text"></i>
                </div>
                <h3 class="feature-title">智能解析</h3>
                <p class="feature-desc">支持 PDF、Word、Markdown 等多种格式，AI 自动识别流程节点、决策点和连接关系</p>
            </div>

            <div class="feature-card scale-in stagger-2">
                <div class="feature-icon">
                    <i data-lucide="palette"></i>
                </div>
                <h3 class="feature-title">矢量图库</h3>
                <p class="feature-desc">内置 10,000+ 精选矢量图标，根据业务场景智能匹配，支持自定义样式</p>
            </div>

            <div class="feature-card scale-in stagger-3">
                <div class="feature-icon">
                    <i data-lucide="zap"></i>
                </div>
                <h3 class="feature-title">秒级生成</h3>
                <p class="feature-desc">从文档到成品，最快 5 秒完成，大幅提升工作效率，告别手动绘图</p>
            </div>

            <div class="feature-card scale-in stagger-1">
                <div class="feature-icon">
                    <i data-lucide="wand-2"></i>
                </div>
                <h3 class="feature-title">AI 智能优化</h3>
                <p class="feature-desc">自动优化布局、调整间距、美化样式，让每个流程图都专业美观</p>
            </div>

            <div class="feature-card scale-in stagger-2">
                <div class="feature-icon">
                    <i data-lucide="users"></i>
                </div>
                <h3 class="feature-title">团队协作</h3>
                <p class="feature-desc">支持多人协同编辑，实时同步，版本管理，让团队协作更高效</p>
