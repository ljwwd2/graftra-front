<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Graftra - 高级动效官网预览</title>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            /* ========================================
               Graftra 翡翠绿系配色系统
               Emerald Growth · Fresh & Professional
               ======================================== */

            /* 主色 - 翡翠绿 (成长、高效、清新) */
            --primary-50: #ecfdf5;
            --primary-100: #d1fae5;
            --primary-200: #a7f3d0;
            --primary-300: #6ee7b7;
            --primary-400: #34d399;
            --primary-500: #10b981;
            --primary-600: #059669;
            --primary-700: #047857;
            --primary-800: #065f46;
            --primary-900: #064e3b;

            /* 辅助色 - 青蓝 (专业、可信、科技) */
            --secondary-50: #ecfeff;
            --secondary-100: #cffafe;
            --secondary-200: #a5f3fc;
            --secondary-300: #67e8f9;
            --secondary-400: #22d3ee;
            --secondary-500: #06b6d4;
            --secondary-600: #0891b2;
            --secondary-700: #0e7490;
            --secondary-800: #155e75;
            --secondary-900: #164e63;

            /* 第二辅助色 - 祖母绿 (清新、活力、自然) */
            --tertiary-50: #f0fdf4;
            --tertiary-100: #dcfce7;
            --tertiary-200: #bbf7d0;
            --tertiary-300: #86efac;
            --tertiary-400: #4ade80;
            --tertiary-500: #22c55e;
            --tertiary-600: #10b981;
            --tertiary-700: #059669;
            --tertiary-800: #16a34a;
            --tertiary-900: #14532d;

            /* 强调色 - 琥珀金 (高亮、提示、温暖) */
            --accent-50: #fffbeb;
            --accent-100: #fef3c7;
            --accent-200: #fde68a;
            --accent-300: #fcd34d;
            --accent-400: #fbbf24;
            --accent-500: #f59e0b;
            --accent-600: #d97706;
            --accent-700: #b45309;
            --accent-800: #92400e;
            --accent-900: #78350f;

            /* 强调色2 - 玫瑰红 (警示、删除、强调) */
            --accent2-50: #fff1f2;
            --accent2-100: #ffe4e6;
            --accent2-200: #fecdd3;
            --accent2-300: #fda4af;
            --accent2-400: #fb7185;
            --accent2-500: #f43f5e;
            --accent2-600: #e11d48;
            --accent2-700: #be123c;
            --accent2-800: #9f1239;
            --accent2-900: #881337;

            /* 中性色 - 蓝灰 (现代、干净) */
            --slate-50: #f8fafc;
            --slate-100: #f1f5f9;
            --slate-200: #e2e8f0;
            --slate-300: #cbd5e1;
            --slate-400: #94a3b8;
            --slate-500: #64748b;
            --slate-600: #475569;
            --slate-700: #334155;
            --slate-800: #1e293b;
            --slate-900: #0f172a;

            /* 主要颜色变量 */
            --primary: var(--primary-600);
            --primary-light: var(--primary-500);
            --primary-dark: var(--primary-700);
            --secondary: var(--secondary-600);
            --accent: var(--accent-600);
            --bg: var(--slate-50);
            --text: var(--slate-900);
            --text-muted: var(--slate-500);
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            line-height: 1.6;
            color: var(--text);
            background: var(--bg);
            overflow-x: hidden;
        }

        /* ============ 高级动效基础类 ============ */
        .fade-in {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s ease-out, transform 0.8s ease-out;
        }

        .fade-in.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .fade-in-left {
            opacity: 0;
            transform: translateX(-50px);
            transition: opacity 0.8s ease-out, transform 0.8s ease-out;
        }

        .fade-in-left.visible {
            opacity: 1;
            transform: translateX(0);
        }

        .fade-in-right {
            opacity: 0;
            transform: translateX(50px);
            transition: opacity 0.8s ease-out, transform 0.8s ease-out;
        }

        .fade-in-right.visible {
            opacity: 1;
            transform: translateX(0);
        }

        .scale-in {
            opacity: 0;
            transform: scale(0.9);
            transition: opacity 0.6s ease-out, transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .scale-in.visible {
            opacity: 1;
            transform: scale(1);
        }

        .stagger-1 { transition-delay: 0.1s; }
        .stagger-2 { transition-delay: 0.2s; }
        .stagger-3 { transition-delay: 0.3s; }
        .stagger-4 { transition-delay: 0.4s; }

        /* ============ 渐变背景动画 ============ */
        .gradient-bg {
            background: linear-gradient(-45deg, var(--primary-600), var(--secondary-600), var(--tertiary-500), var(--primary-500));
            background-size: 400% 400%;
            animation: gradientShift 15s ease infinite;
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .gradient-bg-subtle {
            background: linear-gradient(135deg, var(--primary-50) 0%, var(--secondary-50) 50%, var(--tertiary-50) 100%);
            background-size: 200% 200%;
            animation: gradientSubtle 20s ease infinite;
        }

        @keyframes gradientSubtle {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* ============ 浮动动画 ============ */
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-20px); }
        }

        @keyframes floatSlow {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }

        .float { animation: float 6s ease-in-out infinite; }
        .float-slow { animation: floatSlow 4s ease-in-out infinite; }

        /* ============ 脉冲动画 ============ */
        @keyframes pulse-glow {
            0%, 100% { box-shadow: 0 0 20px rgba(59, 130, 246, 0.3); }
            50% { box-shadow: 0 0 40px rgba(59, 130, 246, 0.6); }
        }

        .pulse-glow { animation: pulse-glow 2s ease-in-out infinite; }

        /* ============ 旋转动画 ============ */
        @keyframes rotate-slow {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .rotate-slow { animation: rotate-slow 20s linear infinite; }

        /* ============ 打字机效果 ============ */
        .typewriter {
            overflow: hidden;
            white-space: nowrap;
            border-right: 3px solid var(--primary);
            animation: typing 3.5s steps(40, end), blink-caret 0.75s step-end infinite;
        }

        @keyframes typing {
            from { width: 0; }
            to { width: 100%; }
        }

        @keyframes blink-caret {
            from, to { border-color: transparent; }
            50% { border-color: var(--primary); }
        }

        /* ============ 导航栏 ============ */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            padding: 16px 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(5, 150, 105, 0.1);
            transition: all 0.3s ease;
        }

        .navbar.scrolled {
            padding: 12px 60px;
            background: rgba(255, 255, 255, 0.98);
            box-shadow: 0 4px 24px rgba(5, 150, 105, 0.1);
        }

        .navbar-logo {
            font-size: 24px;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        .navbar-logo i {
            color: var(--primary);
            width: 28px;
            height: 28px;
        }

        .nav-links {
            display: flex;
            gap: 4px;
            align-items: center;
        }

        .nav-item {
            position: relative;
        }

        .nav-link {
            text-decoration: none;
            color: var(--text);
            font-weight: 500;
            font-size: 14px;
            padding: 10px 16px;
            border-radius: 8px;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .nav-link:hover {
            color: var(--primary);
            background: rgba(5, 150, 105, 0.08);
        }

        .nav-link i {
            width: 13px;
            height: 13px;
            opacity: 0.4;
            transition: all 0.2s ease;
        }

        .nav-link:hover i {
            opacity: 1;
            transform: rotate(180deg);
        }

        /* 下拉菜单 - 全新设计 */
        .nav-dropdown {
            position: absolute;
            top: calc(100% + 8px);
            left: 50%;
            transform: translateX(-50%) translateY(-8px);
            min-width: 280px;
            background: rgba(255, 255, 255, 0.98);
            border: 1px solid rgba(5, 150, 105, 0.15);
            border-radius: 16px;
            box-shadow: 0 12px 48px rgba(5, 150, 105, 0.12), 0 0 0 1px rgba(5, 150, 105, 0.06);
            opacity: 0;
            visibility: hidden;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            overflow: hidden;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
        }

        .nav-item:hover .nav-dropdown {
            opacity: 1;
            visibility: visible;
            transform: translateX(-50%) translateY(0);
        }

        .dropdown-item {
            display: flex;
            align-items: flex-start;
            gap: 14px;
            padding: 14px 18px;
            text-decoration: none;
            color: var(--text);
            transition: all 0.2s ease;
        }

        .dropdown-item:hover {
            background: linear-gradient(135deg, rgba(5, 150, 105, 0.06) 0%, rgba(8, 145, 178, 0.04) 100%);
        }

        .dropdown-item.disabled:hover {
            background: transparent;
        }

        .dropdown-icon {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: linear-gradient(135deg, rgba(5, 150, 105, 0.1) 0%, rgba(8, 145, 178, 0.08) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
            flex-shrink: 0;
            transition: all 0.25s ease;
        }

        .dropdown-item:hover .dropdown-icon {
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            color: white;
            transform: scale(1.08);
        }

        .dropdown-icon i {
            width: 18px;
            height: 18px;
        }

        .dropdown-content {
            flex: 1;
        }

        .dropdown-title {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 3px;
            transition: color 0.2s ease;
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 4px;
        }

        .dropdown-desc {
            font-size: 12px;
            color: var(--text-muted);
            line-height: 1.4;
        }

        .dropdown-item:hover .dropdown-title {
            color: var(--primary);
        }

        /* 下拉菜单分隔 */
        .dropdown-divider {
            padding: 8px 18px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: var(--text-muted);
            background: rgba(0, 0, 0, 0.02);
        }

        /* 下拉菜单禁用状态 - 即将推出 */
        .dropdown-item.disabled {
            opacity: 0.5;
            cursor: not-allowed;
            pointer-events: none;
        }

        .dropdown-item.disabled .dropdown-icon {
            background: rgba(148, 163, 184, 0.1);
            color: var(--slate-400);
        }

        .dropdown-item.disabled .dropdown-title {
            color: var(--slate-400);
        }

        .dropdown-item.disabled .dropdown-desc {
            color: var(--slate-300);
        }

        /* 即将推出标签 */
        .coming-soon-tag {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 2px 8px;
            background: linear-gradient(135deg, var(--accent-300) 0%, var(--accent-400) 100%);
            border-radius: 12px;
            font-size: 10px;
            font-weight: 700;
            color: #92400e;
            margin-left: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .coming-soon-tag i {
            width: 10px;
            height: 10px;
        }

        .navbar-actions {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        /* 移动端菜单按钮 */
        .mobile-menu-btn {
            display: none;
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: transparent;
            border: none;
            cursor: pointer;
            align-items: center;
            justify-content: center;
            gap: 6px;
            flex-direction: column;
        }

        .mobile-menu-btn span {
            width: 20px;
            height: 2px;
            background: var(--text);
            border-radius: 2px;
            transition: all 0.3s ease;
        }

        .mobile-menu-btn.active span:nth-child(1) {
            transform: rotate(45deg) translate(5px, 5px);
        }

        .mobile-menu-btn.active span:nth-child(2) {
            opacity: 0;
        }

        .mobile-menu-btn.active span:nth-child(3) {
            transform: rotate(-45deg) translate(5px, -5px);
        }

        /* 移动端菜单遮罩 */
        .mobile-menu-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.5);
            z-index: 998;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .mobile-menu-overlay.active {
            opacity: 1;
        }

        /* 移动端导航菜单 */
        .mobile-nav-menu {
            display: none;
            position: fixed;
            top: 0;
            right: -100%;
            width: 280px;
            height: 100vh;
            background: rgba(255, 255, 255, 0.98);
            border-left: 1px solid rgba(5, 150, 105, 0.15);
            z-index: 999;
            padding: 80px 24px 24px;
            overflow-y: auto;
            transition: right 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: -10px 0 40px rgba(5, 150, 105, 0.15);
        }

        .mobile-nav-menu.active {
            right: 0;
        }

        .mobile-nav-section {
            margin-bottom: 32px;
        }

        .mobile-nav-title {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
            margin-bottom: 16px;
        }

        .mobile-nav-link {
            display: block;
            padding: 14px 16px;
            color: var(--text);
            text-decoration: none;
            font-size: 16px;
            font-weight: 500;
            border-radius: 10px;
            transition: all 0.2s ease;
            margin-bottom: 4px;
        }

        .mobile-nav-link:hover {
            background: rgba(59, 130, 246, 0.06);
            color: var(--primary);
        }

        /* 移动端禁用链接样式 */
        .mobile-nav-link.disabled {
            opacity: 0.5;
            cursor: not-allowed;
            pointer-events: none;
            color: var(--slate-400) !important;
        }

        .mobile-nav-link.disabled:hover {
            background: transparent;
            color: var(--slate-400) !important;
        }

        /* 移动端即将推出标签 */
        .mobile-nav-link .coming-soon-tag {
            margin-left: 6px;
            padding: 2px 6px;
            font-size: 9px;
            display: inline-flex;
            align-items: center;
        }

        .mobile-nav-cta {
            margin-top: 24px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        /* 全新按钮样式 */
        .btn {
            padding: 10px 20px;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.25s ease;
            cursor: pointer;
            border: none;
            font-size: 14px;
        }

        .btn i {
            width: 16px;
            height: 16px;
        }

        .btn-ghost {
            background: transparent;
            color: var(--text);
            border: 1.5px solid rgba(5, 150, 105, 0.2);
        }

        .btn-ghost:hover {
            border-color: rgba(5, 150, 105, 0.4);
            background: rgba(5, 150, 105, 0.05);
            color: var(--primary);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            color: white;
            box-shadow: 0 2px 8px rgba(5, 150, 105, 0.25);
            position: relative;
            overflow: hidden;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(5, 150, 105, 0.35);
        }

        .btn-primary::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transform: translateX(-100%);
            transition: transform 0.6s ease;
        }

        .btn-primary:hover::before {
            transform: translateX(100%);
        }

        /* ============ Hero 区域 ============ */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
            padding: 100px 60px 80px;
        }

        .hero-bg-subtle {
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 10% 20%, rgba(5, 150, 105, 0.05) 0%, transparent 40%),
                        radial-gradient(circle at 90% 80%, rgba(8, 145, 178, 0.04) 0%, transparent 40%);
            pointer-events: none;
            z-index: 0;
        }

        /* 点状背景图案 */
        .hero-bg-pattern {
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle, rgba(5, 150, 105, 0.06) 1px, transparent 1px);
            background-size: 20px 20px;
            opacity: 0.8;
            pointer-events: none;
            z-index: 1;
        }

        /* Hero 左右布局 */
        .hero-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            max-width: 1280px;
            margin: 0 auto;
            width: 100%;
            position: relative;
            z-index: 10;
            align-items: center;
        }

        .hero-left {
            display: flex;
            flex-direction: column;
            position: relative;
            z-index: 10;
        }

        .hero-right {
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            z-index: 10;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
            background: rgba(5, 150, 105, 0.1);
            border: 1px solid rgba(5, 150, 105, 0.2);
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 28px;
            width: fit-content;
        }

        .hero-title {
            font-size: 56px;
            font-weight: 800;
            letter-spacing: -0.02em;
            margin-bottom: 20px;
            line-height: 1.1;
            color: var(--text);
        }

        .hero-subtitle {
            font-size: 17px;
            color: var(--text-muted);
            margin-bottom: 32px;
            max-width: 480px;
            line-height: 1.65;
        }

        .hero-slogan {
            font-size: 20px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 12px;
        }

        .hero-actions {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
            position: relative;
            z-index: 10;
        }

        .hero-actions .btn {
            position: relative;
            z-index: 1;
        }

        /* ============ 浏览器样机 ============ */
        .browser-mockup {
            width: 100%;
            max-width: 520px;
            background: white;
            border: 1px solid rgba(5, 150, 105, 0.15);
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(5, 150, 105, 0.15), 0 0 0 1px rgba(5, 150, 105, 0.08);
            overflow: hidden;
            position: relative;
        }

        .browser-header {
            background: #f1f5f9;
            padding: 14px 16px;
            display: flex;
            align-items: center;
            gap: 8px;
            border-bottom: 1px solid rgba(5, 150, 105, 0.1);
        }

        .browser-dots {
            display: flex;
            gap: 6px;
        }

        .browser-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #CBD5E1;
        }

        .browser-dot:nth-child(1) { background: #EF4444; }
        .browser-dot:nth-child(2) { background: #F59E0B; }
        .browser-dot:nth-child(3) { background: #22C55E; }

        .browser-address {
            flex: 1;
            background: white;
            border-radius: 6px;
            padding: 6px 12px;
            font-size: 12px;
            color: var(--text-muted);
            text-align: center;
            margin-left: 12px;
        }

        .browser-content {
            padding: 24px;
            background: #f8fafc;
            position: relative;
            min-height: 320px;
        }

        /* 点状网格背景 */
        .flow-grid {
            position: absolute;
            inset: 24px;
            background-image: radial-gradient(circle, rgba(0, 0, 0, 0.04) 1px, transparent 1px);
            background-size: 16px 16px;
        }

        /* 流程节点容器 */
        .flow-nodes {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            gap: 40px;
            padding: 20px 0;
        }

        .flow-row {
            display: flex;
            align-items: center;
            gap: 40px;
            position: relative;
        }

        .flow-row:nth-child(2) {
            justify-content: flex-end;
        }

        /* 流程节点 */
        .flow-node {
            background: white;
            border: 2px solid rgba(5, 150, 105, 0.2);
            border-radius: 12px;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 2px 12px rgba(5, 150, 105, 0.1);
            position: relative;
            min-width: 140px;
            transition: transform 0.3s ease;
        }

        .flow-node:hover {
            transform: translateY(-2px);
            border-color: rgba(5, 150, 105, 0.4);
        }

        .flow-node-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .flow-node-icon i {
            width: 16px;
            height: 16px;
        }

        .flow-node-text {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
        }

        /* 节点样式 */
        .flow-node.cta {
            border: 2px solid #22C55E;
        }

        .flow-node.cta .flow-node-icon {
            background: rgba(34, 197, 94, 0.1);
            color: #22C55E;
        }

        .flow-node.register {
            border: 2px solid #3B82F6;
        }

        .flow-node.register .flow-node-icon {
            background: rgba(59, 130, 246, 0.1);
            color: #3B82F6;
        }

        .flow-node.resource {
            border: 2px solid #F97316;
        }

        .flow-node.resource .flow-node-icon {
            background: rgba(249, 115, 22, 0.1);
            color: #F97316;
        }

        .flow-node.thankyou {
            border: 2px solid #94A3B8;
        }

        .flow-node.thankyou .flow-node-icon {
            background: rgba(148, 163, 184, 0.1);
            color: #94A3B8;
        }

        /* 连接箭头 */
        .flow-arrow {
            position: absolute;
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            font-weight: 500;
        }

        .flow-arrow.vertical {
            flex-direction: column;
            gap: 2px;
        }

        .flow-arrow-label {
            background: white;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 10px;
            color: var(--text-muted);
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
        }

        .flow-arrow-blue {
            color: #3B82F6;
        }

        .flow-arrow-red {
            color: #EF4444;
        }

        /* 浏览器底部控制 */
        .browser-footer {
            position: absolute;
            bottom: 16px;
            right: 16px;
            display: flex;
            gap: 8px;
            background: white;
            padding: 6px 10px;
            border-radius: 8px;
            box-shadow: 0 2px 12px rgba(5, 150, 105, 0.1);
        }

        .browser-control {
            width: 28px;
            height: 28px;
            border-radius: 6px;
            background: #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            font-size: 13px;
            font-weight: 600;
        }

        .browser-control:hover {
            background: #e2e8f0;
        }

        /* ============ 输入文本区域 ============ */
        .text-input-area {
            background: white;
            border: 2px solid rgba(5, 150, 105, 0.15);
            border-radius: 12px;
            padding: 16px;
            box-shadow: 0 2px 12px rgba(5, 150, 105, 0.08);
            margin-bottom: 20px;
        }

        .text-input-header {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 12px;
            padding-bottom: 10px;
            border-bottom: 1px solid rgba(5, 150, 105, 0.15);
        }

        .text-input-header i {
            width: 16px;
            height: 16px;
        }

        .text-input-content {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .text-line {
            font-size: 12px;
            color: var(--text-muted);
            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;
            line-height: 1.6;
        }

        /* ============ 转换箭头 ============ */
        .convert-arrow {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin: 8px 0;
        }

        .convert-arrow i {
            width: 24px;
            height: 24px;
            color: #3B82F6;
        }

        .convert-label {
            font-size: 11px;
            font-weight: 600;
            color: #3B82F6;
            background: rgba(59, 130, 246, 0.1);
            padding: 4px 10px;
            border-radius: 12px;
            margin-top: 4px;
        }

        /* ============ 生成的流程图 ============ */
        .generated-flowchart {
            background: white;
            border: 2px solid rgba(5, 150, 105, 0.15);
            border-radius: 12px;
            padding: 20px 16px;
            box-shadow: 0 2px 12px rgba(5, 150, 105, 0.08);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
        }

        .flow-node.inline-node {
            min-width: auto;
            padding: 10px 16px;
        }

        .flow-node.inline-node.start {
            border-color: #22C55E;
        }

        .flow-node.inline-node.start .flow-node-icon {
            background: rgba(34, 197, 94, 0.1);
            color: #22C55E;
        }

        .flow-node.inline-node.success {
            border-color: #F97316;
        }

        .flow-node.inline-node.success .flow-node-icon {
            background: rgba(249, 115, 22, 0.1);
            color: #F97316;
        }

        .flow-arrow-down {
            width: 0;
            height: 0;
            border-left: 6px solid transparent;
            border-right: 6px solid transparent;
            border-top: 10px solid #3B82F6;
        }

        /* ============ 响应式 ============ */
        @media (max-width: 1024px) {
            .hero-container {
                grid-template-columns: 1fr;
                gap: 60px;
            }
            .hero {
                padding: 80px 40px 60px;
            }
            .hero-title {
                font-size: 44px;
            }
            .browser-mockup {
                max-width: 100%;
            }
        }

        @media (max-width: 768px) {
            .navbar {
                padding: 12px 20px;
            }

            .navbar-logo {
                font-size: 20px;
            }

            .navbar-logo i {
                width: 24px;
                height: 24px;
            }

            /* 显示移动端菜单按钮 */
            .mobile-menu-btn {
                display: flex;
            }

            .mobile-menu-overlay {
                display: block;
            }

            .mobile-nav-menu {
                display: block;
            }

            /* 隐藏桌面端导航 */
            .nav-links {
                display: none !important;
            }

            /* 隐藏桌面端登录按钮 */
            .navbar-actions .btn-ghost {
                display: none;
            }

            /* 在移动端菜单中显示开始使用按钮 */
            .navbar-actions .btn-primary {
                display: none;
            }

            /* Hero 区域 */
            .hero-title {
                font-size: 32px;
            }

            .hero-slogan {
                font-size: 18px;
            }

            .hero-subtitle {
                font-size: 15px;
            }

            .hero-actions {
                flex-direction: column;
                width: 100%;
            }

            .hero-actions .btn {
                width: 100%;
                justify-content: center;
            }

            /* 功能卡片 */
            .features-grid {
                grid-template-columns: 1fr;
            }

            /* 流程时间线 */
            .process-timeline {
                flex-direction: column;
                gap: 40px;
            }

            .process-timeline::before {
                display: none;
            }

            .section-title {
                font-size: 32px;
            }

            .section-desc {
                font-size: 16px;
            }

            /* 定价部分响应式 */
            .pricing-grid {
                grid-template-columns: 1fr;
                max-width: 400px;
            }

            .pricing-card {
                padding: 32px 24px;
            }

            .pricing-amount {
                font-size: 48px;
            }

            .payment-modal {
                margin: 20px;
                max-width: calc(100% - 40px);
            }

            .payment-qr-modal {
                margin: 20px;
                max-width: calc(100% - 40px);
            }
        }

        /* ============ 功能展示区 ============ */
        .features {
            padding: 120px 40px;
            position: relative;
        }

        .section-header {
            text-align: center;
            margin-bottom: 80px;
        }

        .section-label {
            display: inline-block;
            padding: 8px 20px;
            background: linear-gradient(135deg, rgba(5, 150, 105, 0.1) 0%, rgba(8, 145, 178, 0.08) 100%);
            border: 1px solid rgba(5, 150, 105, 0.2);
            border-radius: 20px;
            font-size: 13px;
            font-weight: 700;
            color: var(--primary);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 20px;
        }

        .section-title {
            font-size: 48px;
            font-weight: 700;
            letter-spacing: -0.02em;
            margin-bottom: 20px;
        }

        .section-desc {
            font-size: 18px;
            color: var(--text-muted);
            max-width: 600px;
            margin: 0 auto;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 32px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .feature-card {
            padding: 40px;
            background: white;
            border: 2px solid rgba(5, 150, 105, 0.1);
            border-radius: 24px;
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            position: relative;
            overflow: hidden;
        }

        .feature-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.4s ease;
        }

        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 30px 60px rgba(5, 150, 105, 0.15);
            border-color: rgba(5, 150, 105, 0.25);
        }

        .feature-card:hover::before {
            transform: scaleX(1);
        }

        .feature-icon {
            width: 64px;
            height: 64px;
            border-radius: 16px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 24px;
            transition: transform 0.3s ease;
        }

        .feature-card:hover .feature-icon {
            transform: scale(1.1) rotate(5deg);
        }

        .feature-icon i {
            width: 32px;
            height: 32px;
        }

        .feature-title {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 12px;
        }

        .feature-desc {
            font-size: 15px;
            color: var(--text-muted);
            line-height: 1.7;
        }

        /* ============ 流程展示区 ============ */
        .process {
            padding: 120px 40px;
            background: linear-gradient(180deg, rgba(5, 150, 105, 0.03) 0%, rgba(8, 145, 178, 0.02) 100%);
        }

        .process-timeline {
            display: flex;
            justify-content: center;
            gap: 60px;
            max-width: 1000px;
            margin: 0 auto;
            position: relative;
        }

        .process-timeline::before {
            content: '';
            position: absolute;
            top: 60px;
            left: 100px;
            right: 100px;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--primary), var(--secondary), transparent);
        }

        .process-step {
            flex: 1;
            text-align: center;
            position: relative;
        }

        .step-number {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: white;
            border: 3px solid var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            font-size: 32px;
            font-weight: 800;
            color: var(--primary);
            position: relative;
            z-index: 1;
            transition: all 0.4s ease;
            box-shadow: 0 10px 30px rgba(5, 150, 105, 0.2);
        }

        .process-step:hover .step-number {
            transform: scale(1.1);
            box-shadow: 0 15px 40px rgba(5, 150, 105, 0.3);
            background: var(--primary);
            color: white;
        }

        .step-title {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .step-desc {
            font-size: 14px;
            color: var(--text-muted);
        }

        /* ============ 定价区域 ============ */
        .pricing {
            padding: 120px 40px;
            background: linear-gradient(180deg, var(--bg) 0%, var(--primary-50) 100%);
            position: relative;
        }

        .pricing-toggle {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 16px;
            margin-bottom: 48px;
        }

        .pricing-toggle-label {
            font-size: 16px;
            font-weight: 600;
            color: var(--text-muted);
            transition: all 0.3s ease;
        }

        .pricing-toggle-label.active {
            color: var(--text);
        }

        .pricing-toggle-switch {
            width: 60px;
            height: 32px;
            background: var(--slate-200);
            border-radius: 16px;
            position: relative;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .pricing-toggle-switch.active {
            background: var(--primary);
        }

        .pricing-toggle-switch::after {
            content: '';
            position: absolute;
            width: 26px;
            height: 26px;
            background: white;
            border-radius: 50%;
            top: 3px;
            left: 3px;
            transition: all 0.3s ease;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
        }

        .pricing-toggle-switch.active::after {
            left: 31px;
        }

        .pricing-badge {
            padding: 6px 12px;
            background: linear-gradient(135deg, var(--accent-500) 0%, var(--accent-600) 100%);
            color: white;
            font-size: 12px;
            font-weight: 700;
            border-radius: 20px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .pricing-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 32px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .pricing-card {
            background: white;
            border-radius: 24px;
            padding: 40px 32px;
            box-shadow: 0 4px 24px rgba(5, 150, 105, 0.08);
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            position: relative;
            border: 2px solid transparent;
        }

        .pricing-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 16px 48px rgba(5, 150, 105, 0.15);
        }

        .pricing-card.popular {
            border-color: var(--primary);
            background: linear-gradient(180deg, rgba(5, 150, 105, 0.02) 0%, white 30%);
        }

        .pricing-card-popular {
            position: absolute;
            top: -14px;
            left: 50%;
            transform: translateX(-50%);
            padding: 6px 20px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            color: white;
            font-size: 13px;
            font-weight: 700;
            border-radius: 20px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .pricing-plan {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 16px;
        }

        .pricing-price {
            display: flex;
            align-items: baseline;
            gap: 4px;
            margin-bottom: 8px;
        }

        .pricing-currency {
            font-size: 24px;
            font-weight: 700;
            color: var(--text);
        }

        .pricing-amount {
            font-size: 56px;
            font-weight: 800;
            color: var(--text);
            line-height: 1;
        }

        .pricing-period {
            font-size: 16px;
            font-weight: 500;
            color: var(--text-muted);
        }

        .pricing-save {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            background: rgba(5, 150, 105, 0.1);
            color: var(--primary);
            font-size: 13px;
            font-weight: 600;
            border-radius: 12px;
            margin-bottom: 24px;
        }

        .pricing-desc {
            font-size: 15px;
            color: var(--text-muted);
            margin-bottom: 32px;
            line-height: 1.6;
        }

        .pricing-features {
            list-style: none;
            margin-bottom: 32px;
        }

        .pricing-feature {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 0;
            border-bottom: 1px solid var(--slate-100);
        }

        .pricing-feature:last-child {
            border-bottom: none;
        }

        .pricing-feature-icon {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .pricing-feature-icon.included {
            background: rgba(5, 150, 105, 0.1);
            color: var(--primary);
        }

        .pricing-feature-icon.excluded {
            background: var(--slate-100);
            color: var(--slate-400);
        }

        .pricing-feature-icon i {
            width: 14px;
            height: 14px;
        }

        .pricing-feature-text {
            font-size: 15px;
            color: var(--text);
        }

        .pricing-feature-text.excluded {
            color: var(--slate-400);
            text-decoration: line-through;
        }

        .pricing-cta {
            width: 100%;
            padding: 16px 24px;
            border-radius: 14px;
            font-size: 16px;
            font-weight: 700;
            text-align: center;
            text-decoration: none;
            display: block;
            transition: all 0.3s ease;
        }

        .pricing-cta-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            color: white;
            box-shadow: 0 4px 16px rgba(5, 150, 105, 0.25);
        }

        .pricing-cta-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(5, 150, 105, 0.35);
        }

        .pricing-cta-secondary {
            background: var(--slate-100);
            color: var(--text);
        }

        .pricing-cta-secondary:hover {
            background: var(--slate-200);
        }

        /* ============ 支付弹窗 ============ */
        .payment-modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(8px);
            z-index: 2000;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .payment-modal-overlay.active {
            display: flex;
        }

        .payment-modal {
            background: white;
            border-radius: 24px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
            animation: modalSlideIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        @keyframes modalSlideIn {
            from {
                opacity: 0;
                transform: translateY(40px) scale(0.95);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .payment-modal-header {
            padding: 24px 28px;
            border-bottom: 1px solid var(--slate-100);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .payment-modal-title {
            font-size: 18px;
            font-weight: 700;
            color: var(--text);
        }

        .payment-modal-close {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: var(--slate-100);
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
        }

        .payment-modal-close:hover {
            background: var(--slate-200);
        }

        .payment-modal-close i {
            width: 16px;
            height: 16px;
            color: var(--text-muted);
        }

        .payment-modal-body {
            padding: 28px;
        }

        .payment-order-summary {
            background: var(--slate-50);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 24px;
        }

        .payment-order-title {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
        }

        .payment-order-plan {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .payment-order-plan-name {
            font-size: 16px;
            font-weight: 600;
            color: var(--text);
        }

        .payment-order-plan-price {
            font-size: 18px;
            font-weight: 800;
            color: var(--primary);
        }

        .payment-order-plan-period {
            font-size: 13px;
            color: var(--text-muted);
        }

        .payment-methods {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .payment-method-title {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 8px;
        }

        .payment-method {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 16px;
            border: 2px solid var(--slate-200);
            border-radius: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            background: white;
        }

        .payment-method:hover {
            border-color: var(--primary);
            background: rgba(5, 150, 105, 0.02);
        }

        .payment-method.selected {
            border-color: var(--primary);
            background: rgba(5, 150, 105, 0.05);
        }

        .payment-method-icon {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            background: var(--slate-100);
        }

        .payment-method-icon img {
            width: 32px;
            height: 32px;
        }

        .payment-method-icon svg {
            width: 32px;
            height: 32px;
        }

        .payment-method-info {
            flex: 1;
        }

        .payment-method-name {
            font-size: 15px;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 2px;
        }

        .payment-method-desc {
            font-size: 13px;
            color: var(--text-muted);
        }

        .payment-method-check {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            border: 2px solid var(--slate-300);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
        }

        .payment-method.selected .payment-method-check {
            background: var(--primary);
            border-color: var(--primary);
        }

        .payment-method-check i {
            width: 14px;
            height: 14px;
            color: white;
            opacity: 0;
        }

        .payment-method.selected .payment-method-check i {
            opacity: 1;
        }

        .payment-modal-footer {
            padding: 20px 28px;
            border-top: 1px solid var(--slate-100);
        }

        .payment-submit {
            width: 100%;
            padding: 16px;
            border: none;
            border-radius: 14px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            color: white;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 16px rgba(5, 150, 105, 0.25);
        }

        .payment-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(5, 150, 105, 0.35);
        }

        .payment-submit:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .payment-security {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 16px;
            font-size: 13px;
            color: var(--text-muted);
        }

        .payment-security i {
            width: 16px;
            height: 16px;
            color: var(--primary);
        }

        /* ============ 二维码支付 ============ */
        .payment-qr-modal {
            background: white;
            border-radius: 24px;
            width: 100%;
            max-width: 380px;
            box-shadow: 0 24px 80px rgba(0, 0, 0, 0.2);
        }

        .payment-qr-body {
            padding: 32px;
            text-align: center;
        }

        .payment-qr-title {
            font-size: 18px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 8px;
        }

        .payment-qr-desc {
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 24px;
        }

        .payment-qr-code {
            width: 220px;
            height: 220px;
            margin: 0 auto 24px;
            border-radius: 16px;
            background: var(--slate-100);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .payment-qr-code img {
            width: 200px;
            height: 200px;
            border-radius: 12px;
        }

        .payment-qr-code .qr-placeholder {
            color: var(--text-muted);
            font-size: 14px;
        }

        .payment-qr-tips {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px;
            background: rgba(5, 150, 105, 0.05);
            border-radius: 10px;
            font-size: 13px;
            color: var(--primary);
        }

        .payment-qr-tips i {
            width: 16px;
            height: 16px;
        }

        .payment-qr-status {
            margin-top: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-size: 14px;
            color: var(--text-muted);
        }

        .payment-qr-spinner {
            width: 16px;
            height: 16px;
            border: 2px solid var(--slate-200);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* ============ CTA 区域 ============ */
        .cta {
            padding: 120px 40px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .cta-bg {
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
        }

        .cta-content {
            position: relative;
            z-index: 10;
            color: white;
        }

        .cta-title {
            font-size: 52px;
            font-weight: 800;
            margin-bottom: 20px;
        }

        .cta-subtitle {
            font-size: 20px;
            opacity: 0.9;
            margin-bottom: 40px;
            max-width: 500px;
            margin-left: auto;
            margin-right: auto;
        }

        .cta-btn {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            padding: 18px 40px;
            background: white;
            color: var(--primary);
            border-radius: 16px;
            font-size: 18px;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            box-shadow: 0 10px 40px rgba(5, 150, 105, 0.2);
        }

        .cta-btn:hover {
            transform: translateY(-5px) scale(1.05);
            box-shadow: 0 20px 60px rgba(5, 150, 105, 0.3);
        }

        /* CTA 装饰 */
        .cta-decoration {
            position: absolute;
            border-radius: 50%;
            background: rgba(5, 150, 105, 0.1);
        }

        .cta-decoration-1 {
            width: 300px;
            height: 300px;
            top: -150px;
            right: -100px;
        }

        .cta-decoration-2 {
            width: 200px;
            height: 200px;
            bottom: -100px;
            left: -50px;
        }

        /* ============ 页脚 ============ */
        .footer {
            padding: 60px 40px;
            text-align: center;
            border-top: 1px solid rgba(0, 0, 0, 0.05);
        }

        .footer-logo {
            font-size: 28px;
            font-weight: 800;
            color: var(--primary);
            margin-bottom: 20px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .footer-links {
            display: flex;
            gap: 32px;
            justify-content: center;
            margin-bottom: 30px;
        }

        .footer-link {
            color: var(--text-muted);
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .footer-link:hover {
            color: var(--primary);
        }

        .footer-copyright {
            color: var(--text-muted);
            font-size: 14px;
        }

        /* ============ Toast 通知 ============ */
        .toast {
            position: fixed;
            top: 24px;
            left: 50%;
            transform: translateX(-50%) translateY(-100px);
            padding: 14px 20px;
            border-radius: 12px;
            background: white;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
            display: flex;
            align-items: center;
            gap: 12px;
            z-index: 9999;
            opacity: 0;
            transition: all 0.3s ease;
        }

        .toast.show {
            transform: translateX(-50%) translateY(0);
            opacity: 1;
        }

        .toast-icon {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .toast-icon.success {
            background: var(--primary-500);
        }

        .toast-icon.success i {
            color: white;
            width: 14px;
            height: 14px;
        }

        .toast-icon.error {
            background: var(--accent2-500);
        }

        .toast-icon.error i {
            color: white;
            width: 14px;
            height: 14px;
        }

        .toast-message {
            font-size: 14px;
            font-weight: 500;
            color: var(--text);
        }

        /* ============ 响应式 ============ */
        @media (max-width: 768px) {
            .hero-title { font-size: 42px; }
            .features-grid { grid-template-columns: 1fr; }
            .process-timeline { flex-direction: column; gap: 40px; }
            .process-timeline::before { display: none; }
            .section-title { font-size: 32px; }
            .nav-links { display: none; }
        }
    </style>
</head>
