    <!-- 微信支付二维码弹窗 -->
    <div class="payment-modal-overlay" id="wechatQRModal">
        <div class="payment-qr-modal">
            <div class="payment-modal-header">
                <h3 class="payment-modal-title">微信支付</h3>
                <button class="payment-modal-close" onclick="closeWeChatQRModal()">
                    <i data-lucide="x"></i>
                </button>
            </div>

            <div class="payment-qr-body">
                <h4 class="payment-qr-title">请使用微信扫码支付</h4>
                <p class="payment-qr-desc">支付完成后将自动跳转</p>
                <div class="payment-qr-code" id="wechatQRCode">
                    <div class="qr-placeholder">
                        <i data-lucide="loader-2" class="loading-spinner"></i>
                        <div>正在生成支付二维码...</div>
                    </div>
                </div>
                <div class="payment-qr-tips">
                    <i data-lucide="lightbulb"></i>
                    <span>支付过程中请勿关闭窗口</span>
                </div>
                <div class="payment-qr-status" id="wechatQRStatus">
                    <div class="payment-qr-spinner"></div>
                    <span>等待支付中...</span>
                </div>
            </div>
        </div>
    </div>

    <!-- 支付宝支付二维码弹窗 -->
    <div class="payment-modal-overlay" id="alipayQRModal">
        <div class="payment-qr-modal">
            <div class="payment-modal-header">
                <h3 class="payment-modal-title">支付宝支付</h3>
                <button class="payment-modal-close" onclick="closeAlipayQRModal()">
                    <i data-lucide="x"></i>
                </button>
            </div>

            <div class="payment-qr-body">
                <h4 class="payment-qr-title">请使用支付宝扫码支付</h4>
                <p class="payment-qr-desc">支付完成后将自动跳转</p>
                <div class="payment-qr-code" id="alipayQRCode">
                    <div class="qr-placeholder">
                        <i data-lucide="loader-2" class="loading-spinner"></i>
                        <div>正在生成支付二维码...</div>
                    </div>
                </div>
                <div class="payment-qr-tips">
                    <i data-lucide="lightbulb"></i>
                    <span>支付过程中请勿关闭窗口</span>
                </div>
            </div>
        </div>
    </div>

    <script>
        // 初始化 Lucide 图标
        lucide.createIcons();

        // 滚动时导航栏效果
        const navbar = document.getElementById('navbar');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                navbar.classList.add('scrolled');
            } else {
                navbar.classList.remove('scrolled');
            }
        });

        // 滚动进入动画
        const observerOptions = {
            root: null,
            rootMargin: '0px',
            threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, observerOptions);

        // 观察所有需要动画的元素
        document.querySelectorAll('.fade-in, .fade-in-left, .fade-in-right, .scale-in').forEach(el => {
            observer.observe(el);
        });

        // Hero 区域动画初始触发
        setTimeout(() => {
            document.querySelectorAll('.hero .fade-in, .hero .scale-in').forEach(el => {
                el.classList.add('visible');
            });
        }, 300);

        // 平滑滚动
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                const href = this.getAttribute('href');
                // 跳过纯 # 或空链接
                if (!href || href === '#') {
                    return;
                }
                e.preventDefault();
                const target = document.querySelector(href);
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // 移动端菜单功能
        const mobileMenuBtn = document.getElementById('mobileMenuBtn');
        const mobileNavMenu = document.getElementById('mobileNavMenu');
        const mobileMenuOverlay = document.getElementById('mobileMenuOverlay');

        function toggleMobileMenu() {
            mobileMenuBtn.classList.toggle('active');
            mobileNavMenu.classList.toggle('active');
            mobileMenuOverlay.classList.toggle('active');
            document.body.style.overflow = mobileNavMenu.classList.contains('active') ? 'hidden' : '';
        }

        function closeMobileMenu() {
            mobileMenuBtn.classList.remove('active');
            mobileNavMenu.classList.remove('active');
            mobileMenuOverlay.classList.remove('active');
            document.body.style.overflow = '';
        }

        mobileMenuBtn.addEventListener('click', toggleMobileMenu);
        mobileMenuOverlay.addEventListener('click', closeMobileMenu);

        // 点击移动菜单中的链接后关闭菜单
        mobileNavMenu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', closeMobileMenu);
        });

        // ============ 定价页面功能 ============
        let currentPeriod = 'monthly';

        // 周期切换
        const pricingToggle = document.querySelector('.pricing-toggle-switch');
        if (pricingToggle) {
            pricingToggle.addEventListener('click', () => {
                currentPeriod = currentPeriod === 'monthly' ? 'yearly' : 'monthly';
                pricingToggle.classList.toggle('active', currentPeriod === 'yearly');

                // 更新标签
                document.querySelectorAll('.pricing-toggle-label').forEach(label => {
                    label.classList.toggle('active', label.dataset.period === currentPeriod);
                });

                // 更新价格显示
                updatePricingPrices();
            });
        }

        function updatePricingPrices() {
            const priceElements = document.querySelectorAll('.pricing-price');
            priceElements.forEach(el => {
                const monthly = el.dataset.monthly;
                const yearly = el.dataset.yearly;
                if (monthly && yearly) {
                    const amountEl = el.querySelector('.pricing-amount');
                    const periodEl = el.querySelector('.pricing-period');
                    if (currentPeriod === 'yearly') {
                        amountEl.textContent = yearly;
                        periodEl.textContent = '/年';
                    } else {
                        amountEl.textContent = monthly;
                        periodEl.textContent = '/月';
                    }
                }
            });
        }

        // ============ 支付弹窗 ============
        let selectedPaymentMethod = 'wechat';

        function openPaymentModal(plan, period = currentPeriod) {
            const modal = document.getElementById('paymentModal');
            if (modal) {
                modal.classList.add('active');
                document.body.style.overflow = 'hidden';

                // 更新订单信息
                updateOrderSummary(plan, period);
            }
        }

        function closePaymentModal() {
            const modal = document.getElementById('paymentModal');
            if (modal) {
                modal.classList.remove('active');
                document.body.style.overflow = '';
            }
        }

        function updateOrderSummary(plan, period) {
            const planNameEl = document.getElementById('orderPlanName');
            const planPriceEl = document.getElementById('orderPlanPrice');
            const planPeriodEl = document.getElementById('orderPlanPeriod');

            const planNames = {
                'pro': '专业版'
            };

            const prices = {
                'pro': {
                    'monthly': 29,
                    'yearly': 279
                }
            };

            const periodNames = {
                'monthly': '月付',
                'yearly': '年付'
            };

            if (planNameEl) planNameEl.textContent = planNames[plan];
            if (planPriceEl) planPriceEl.textContent = `¥${prices[plan][period]}`;
            if (planPeriodEl) planPeriodEl.textContent = periodNames[period];
        }

        // 支付方式选择
        document.querySelectorAll('.payment-method').forEach(method => {
            method.addEventListener('click', () => {
                document.querySelectorAll('.payment-method').forEach(m => m.classList.remove('selected'));
                method.classList.add('selected');
                selectedPaymentMethod = method.dataset.method;

                // 启用/禁用提交按钮
                const submitBtn = document.getElementById('paymentSubmit');
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.textContent = '确认支付';
                }
            });
        });

        // 提交支付
        function submitPayment() {
            const submitBtn = document.getElementById('paymentSubmit');
            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<div class="loading-spinner"></div> 处理中...';
            }

            // 模拟API调用
            setTimeout(() => {
                if (selectedPaymentMethod === 'wechat') {
                    closePaymentModal();
                    openWeChatQRModal();
                } else if (selectedPaymentMethod === 'alipay') {
                    closePaymentModal();
                    openAlipayQRModal();
                }
            }, 1000);
        }

        // ============ 微信支付弹窗 ============
        let wechatCheckTimer = null;

        function openWeChatQRModal() {
            const modal = document.getElementById('wechatQRModal');
            if (modal) {
                modal.classList.add('active');
                document.body.style.overflow = 'hidden';

                // 模拟生成二维码
                const qrCodeEl = document.getElementById('wechatQRCode');
                if (qrCodeEl) {
                    qrCodeEl.innerHTML = `
                        <div class="qr-placeholder">
                            <i data-lucide="qr-code" style="width: 64px; height: 64px; margin: 0 auto 16px; display: block;"></i>
                            <div>请使用微信扫码支付</div>
                            <div style="font-size: 12px; margin-top: 8px;">¥29.00</div>
                        </div>
                    `;
                    lucide.createIcons();
                }

                // 模拟轮询支付状态
                startWeChatStatusCheck();
            }
        }

        function closeWeChatQRModal() {
            const modal = document.getElementById('wechatQRModal');
            if (modal) {
                modal.classList.remove('active');
                document.body.style.overflow = '';
            }
            if (wechatCheckTimer) {
                clearInterval(wechatCheckTimer);
                wechatCheckTimer = null;
            }
        }

        function startWeChatStatusCheck() {
            let count = 0;
            const maxCount = 60; // 最多检查60次（5分钟）

            wechatCheckTimer = setInterval(() => {
                count++;

                // 模拟支付成功
                if (count >= 5) {
                    clearInterval(wechatCheckTimer);
                    wechatCheckTimer = null;

                    const statusEl = document.getElementById('wechatQRStatus');
                    if (statusEl) {
                        statusEl.innerHTML = `
                            <i data-lucide="check-circle" style="width: 24px; height: 24px; color: var(--primary);"></i>
                            <span>支付成功！正在跳转...</span>
                        `;
                        lucide.createIcons();
                    }

                    setTimeout(() => {
                        closeWeChatQRModal();
                        showToast('升级成功！您现在是专业版用户', 'success');

                        // 跳转到应用页面
                        window.location.href = 'app.html';
                    }, 2000);
                }
            }, 3000);
        }

        // ============ 支付宝支付弹窗 ============
        function openAlipayQRModal() {
            const modal = document.getElementById('alipayQRModal');
            if (modal) {
                modal.classList.add('active');
                document.body.style.overflow = 'hidden';

                // 模拟生成二维码
                const qrCodeEl = document.getElementById('alipayQRCode');
                if (qrCodeEl) {
                    qrCodeEl.innerHTML = `
                        <div class="qr-placeholder">
                            <i data-lucide="qr-code" style="width: 64px; height: 64px; margin: 0 auto 16px; display: block;"></i>
                            <div>请使用支付宝扫码支付</div>
                            <div style="font-size: 12px; margin-top: 8px;">¥29.00</div>
                        </div>
                    `;
                    lucide.createIcons();
                }
            }
        }

        function closeAlipayQRModal() {
            const modal = document.getElementById('alipayQRModal');
            if (modal) {
                modal.classList.remove('active');
                document.body.style.overflow = '';
            }
        }

        // 关闭弹窗（点击遮罩）
        document.querySelectorAll('.payment-modal-overlay').forEach(overlay => {
            overlay.addEventListener('click', (e) => {
                if (e.target === overlay) {
                    overlay.classList.remove('active');
                    document.body.style.overflow = '';

                    // 清除定时器
                    if (wechatCheckTimer) {
                        clearInterval(wechatCheckTimer);
                        wechatCheckTimer = null;
                    }
                }
            });
        });

        // 关闭按钮
        document.querySelectorAll('.payment-modal-close').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.payment-modal-overlay').forEach(modal => {
                    modal.classList.remove('active');
                });
                document.body.style.overflow = '';

                if (wechatCheckTimer) {
                    clearInterval(wechatCheckTimer);
                    wechatCheckTimer = null;
                }
            });
        });

        // Toast 提示
        function showToast(message, type = 'success') {
            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.innerHTML = `
                <div class="toast-icon ${type}">
                    <i data-lucide="${type === 'success' ? 'check' : 'alert-circle'}"></i>
                </div>
                <div class="toast-message">${message}</div>
            `;
            document.body.appendChild(toast);
            lucide.createIcons();

            setTimeout(() => toast.classList.add('show'), 10);
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }
    </script>
</body>
</html>
